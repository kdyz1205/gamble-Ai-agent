# ── Database (PostgreSQL) ──
# Use Vercel Postgres, Supabase, Neon, or Railway
DATABASE_URL="postgresql://user:password@host:5432/challengeai?sslmode=require"

# ── NextAuth ──
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ── Google OAuth ──
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Anthropic AI (Claude) ─────────────────────────────────────────
# 1) Create account: https://console.anthropic.com/
# 2) Billing: add payment method so API calls work (Usage → set budget if you want a cap).
# 3) API Keys → Create Key → copy sk-ant-api03-...
# 4) Paste below and restart `npm run dev`.
#
# Without ANTHROPIC_API_KEY: parse + judge use local fallbacks (no real Claude).
#
# Run `npm run pricing` to print rough margin table (edit assumptions in src/lib/pricing-model.ts).
ANTHROPIC_API_KEY=""

# Other LLM backends (optional — UI “Oracle LLM” panel + src/lib/llm-router.ts)
# OPENAI_API_KEY=""
# GOOGLE_AI_API_KEY=""
# GROQ_API_KEY=""
# MISTRAL_API_KEY=""
# DEEPSEEK_API_KEY=""
# XAI_API_KEY=""
# TOGETHER_API_KEY=""
# FIREWORKS_API_KEY=""
# AZURE_OPENAI_API_KEY=""
# AZURE_OPENAI_BASE_URL=""   # e.g. https://YOUR_RESOURCE.openai.azure.com/openai/deployments/YOUR_DEPLOYMENT
# AZURE_OPENAI_API_VERSION="2024-08-01-preview"

# Default provider id for cron/auto-judge when request body has no providerId (see llm-providers.ts)
# ORACLE_DEFAULT_PROVIDER="anthropic"

# Evidence media (vision judge) — optional host allowlist (comma-separated), else any public https host after SSRF checks
# EVIDENCE_URL_HOST_ALLOWLIST="cdn.example.com,files.example.com"

# Optional — override $/million tokens for npm run pricing (defaults in pricing-model.ts)
# ANTHROPIC_HAIKU_IN=1
# ANTHROPIC_HAIKU_OUT=5
# ANTHROPIC_SONNET_IN=3
# ANTHROPIC_SONNET_OUT=15

# ══════════════════════════════════════════════
# ON-CHAIN USAGE TOKEN (optional — enables true tokenization)
# Without these, the app runs with off-chain credits in PostgreSQL.
# With these, USAGE is a real ERC-20 token on Base.
# ══════════════════════════════════════════════

# Network: "base-sepolia" (testnet) or "base" (mainnet)
X402_NETWORK="base-sepolia"

# RPC URL (get free at https://www.alchemy.com or https://www.infura.io)
RPC_URL="https://sepolia.base.org"

# Deployed contract addresses (after running forge deploy)
USAGE_TOKEN_ADDRESS=""
ESCROW_ADDRESS=""

# Server wallet private key — used to burn tokens + settle challenges
# This wallet must be set as an authorized burner/judge in the contracts
SERVER_PRIVATE_KEY=""

# USDC contract address on Base Sepolia
USDC_ADDRESS="0x036CbD53842c5426634e7929541eC2318f3dCF7e"
