generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════
// NEXTAUTH MODELS
// ═══════════════════════════════════════

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ═══════════════════════════════════════
// USERS
// ═══════════════════════════════════════

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  username      String    @unique
  name          String?
  image         String?
  passwordHash  String?
  bio           String?
  credits       Int       @default(10) // starting credits — enough for a few rounds
  totalCreditsWon  Int    @default(0)
  totalCreditsLost Int    @default(0)
  totalCreditsBought Int  @default(0)
  evmAddress    String?   @unique // EVM wallet for on-chain USAGE tokens
  latitude      Float?
  longitude     Float?
  locationUpdatedAt DateTime?
  isOnline      Boolean   @default(false)
  lastSeenAt    DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  challengesCreated  Challenge[]    @relation("ChallengeCreator")
  participations     Participant[]
  evidenceSubmissions Evidence[]
  judgmentsGiven     Judgment[]     @relation("JudgeUser")
  judgmentsWon       Judgment[]     @relation("WinnerUser")
  transactions       CreditTx[]
  activityEvents     ActivityEvent[]
  judgeJobsRequested JudgeJob[]     @relation("JudgeJobRequester")
  auditLogsActor     AuditLog[]     @relation("AuditLogActor")
  auditLogsTarget    AuditLog[]     @relation("AuditLogTarget")
}

// ═══════════════════════════════════════
// CREDIT TRANSACTIONS
// ═══════════════════════════════════════

model CreditTx {
  id           String   @id @default(cuid())
  userId       String
  type         String   // topup | ai_parse | ai_judge | stake | win | loss | refund | bonus
  amount       Int      // positive = gained, negative = spent
  balanceAfter Int
  description  String?
  challengeId  String?
  x402TxHash   String?  // on-chain tx hash for USDC top-ups
  createdAt    DateTime @default(now())

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge    Challenge? @relation(fields: [challengeId], references: [id])
}

// ═══════════════════════════════════════
// CHALLENGES
// ═══════════════════════════════════════

model Challenge {
  id            String   @id @default(cuid())
  creatorId     String
  title         String
  description   String?
  type          String   // Fitness | Cooking | Coding | Learning | Games | Prediction | General
  status        String   @default("draft") // draft | open | funded | live | judging | resolved | void | cancelled | disputed

  // ── Market structure ──
  marketType    String   @default("challenge") // yes_no | threshold | head_to_head | challenge
  proposition   String?  // canonical proposition ("Will X happen?", "Can I do Y?")

  // ── Stakes ──
  stake         Int      @default(0) // credits wagered per participant
  stakeToken    String   @default("credits") // credits | usdc | eth

  // ── Timing ──
  deadline      DateTime?
  eventTime     String?  // human-readable event time ("April 10", "tomorrow 3pm")
  joinWindow    String?  // how long others can join ("24 hours", "until event")
  proofWindow   String?  // how long to submit proof ("48 hours after event")

  // ── Rules & Evidence ──
  rules         String?
  evidenceType  String   @default("self_report") // video | photo | gps | self_report

  // ── Settlement ──
  settlementMode String  @default("mutual_confirmation") // oracle | arbiter | mutual_confirmation
  proofSource   String?  // who submits the result ("creator", "opponent", "both", username)
  arbiter       String?  // who decides disputes (username or "ai")
  fallbackRule  String?  // what happens if no proof ("refund_if_no_proof", "forfeit_if_no_proof")
  disputeWindow String?  // how long to dispute ("12 hours", "24 hours")

  // ── Visibility ──
  isPublic      Boolean  @default(false)
  visibility    String   @default("private") // private | invite_only | public
  maxParticipants Int    @default(2)

  // ── On-chain anchoring (optional) ──
  paramsHash    String?  // hash of market params at creation time
  evidenceHash  String?  // hash of submitted evidence
  resolutionHash String? // hash of final resolution packet
  escrowTxHash  String?  // on-chain escrow creation tx
  settleTxHash  String?  // on-chain settlement tx

  // ── AI ──
  aiReview      Boolean  @default(true)
  aiModel       String?  // which model was used for judging

  // ── Metadata ──
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  discoveryLat        Float?
  discoveryLng        Float?
  discoveryCapturedAt DateTime?

  creator       User          @relation("ChallengeCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  participants  Participant[]
  evidence      Evidence[]
  judgments     Judgment[]
  creditTxs     CreditTx[]
  activityEvents ActivityEvent[]
  judgeJobs     JudgeJob[]
  auditLogs     AuditLog[]    @relation("AuditLogChallenge")
}

model Participant {
  id           String   @id @default(cuid())
  challengeId  String
  userId       String
  role         String   @default("opponent") // creator | opponent | spectator
  status       String   @default("pending")  // pending | accepted | declined | completed
  joinedAt     DateTime @default(now())

  challenge    Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
}

// ═══════════════════════════════════════
// EVIDENCE & JUDGMENT
// ═══════════════════════════════════════

model Evidence {
  id           String   @id @default(cuid())
  challengeId  String
  userId       String
  type         String   // video | photo | gps | text
  url          String?
  description  String?
  metadata     String?  // JSON string
  createdAt    DateTime @default(now())

  challenge    Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Judgment {
  id           String   @id @default(cuid())
  challengeId  String
  judgeId      String?
  winnerId     String?
  method       String   @default("ai") // ai | manual | community_vote
  aiModel      String?
  reasoning    String?
  confidence   Float?
  status       String   @default("pending") // pending | completed | disputed
  createdAt    DateTime @default(now())

  challenge    Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  judge        User?     @relation("JudgeUser", fields: [judgeId], references: [id])
  winner       User?     @relation("WinnerUser", fields: [winnerId], references: [id])
  judgeJobs    JudgeJob[]
}

// ═══════════════════════════════════════
// JUDGE JOBS (async AI judgment)
// ═══════════════════════════════════════

model JudgeJob {
  id                String   @id @default(cuid())
  challengeId       String
  requestedByUserId String
  status            String   @default("pending") // pending | processing | completed | failed
  tierId            Int      @default(1)
  providerId        String?
  model             String?
  webhookUrl        String?
  error             String?
  resultJson        String?
  judgmentId        String?
  creditsUsed       Int?
  creditsRemaining  Int?
  txHash            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  challenge         Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  requestedBy       User      @relation("JudgeJobRequester", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  judgment          Judgment? @relation(fields: [judgmentId], references: [id])

  @@index([challengeId, status])
}

// ═══════════════════════════════════════
// AUDIT LOG
// ═══════════════════════════════════════

model AuditLog {
  id           String   @id @default(cuid())
  action       String
  actorUserId  String?
  targetUserId String?
  challengeId  String?
  payload      String?  // JSON string (SQLite doesn't support JSONB)
  createdAt    DateTime @default(now())

  actor        User?      @relation("AuditLogActor", fields: [actorUserId], references: [id])
  target       User?      @relation("AuditLogTarget", fields: [targetUserId], references: [id])
  challenge    Challenge? @relation("AuditLogChallenge", fields: [challengeId], references: [id])

  @@index([challengeId])
  @@index([actorUserId])
  @@index([createdAt])
}

// ═══════════════════════════════════════
// ACTIVITY FEED
// ═══════════════════════════════════════

model ActivityEvent {
  id           String   @id @default(cuid())
  type         String
  message      String
  userId       String?
  challengeId  String?
  metadata     String?
  createdAt    DateTime @default(now())

  user         User?      @relation(fields: [userId], references: [id])
  challenge    Challenge? @relation(fields: [challengeId], references: [id])
}
